# Database
DATABASE_URL="postgresql://tll_user:CHANGE_THIS_PASSWORD@db:5432/tll_db"
DB_PASSWORD="CHANGE_THIS_STRONG_DB_PASSWORD"

# JWT Secret — generate with: openssl rand -base64 48
JWT_SECRET="CHANGE_THIS_TO_A_RANDOM_256_BIT_SECRET"

# App
NEXT_PUBLIC_APP_URL="https://YOUR_DOMAIN.COM"
NEXT_PUBLIC_APP_NAME="Thai-Lao Logistics"
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# Domain (used by setup-vps.sh for SSL + nginx)
DOMAIN="YOUR_DOMAIN.COM"
ADMIN_EMAIL="admin@YOUR_DOMAIN.COM"

# File uploads
UPLOAD_DIR="/app/uploads"
UPLOAD_MAX_SIZE_MB="5"

# Node environment
NODE_ENV="production"

# Production Docker image (set automatically by CI/CD deploy.yml)
# Format: ghcr.io/YOUR_GITHUB_ORG/lao_thai_logistic-main:sha-<commit>
WEB_IMAGE="ghcr.io/YOUR_GITHUB_ORG/lao_thai_logistic-main:latest"

# Monitoring (Sentry) — optional
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
SENTRY_ENVIRONMENT="production"

# Grafana (observability stack) — optional
GF_SECURITY_ADMIN_USER="admin"
GF_SECURITY_ADMIN_PASSWORD="CHANGE_THIS_GRAFANA_PASSWORD"

# Backup scripts
DB_NAME="tll_db"
DB_USER="tll_user"
BACKUP_DIR="./backups"
